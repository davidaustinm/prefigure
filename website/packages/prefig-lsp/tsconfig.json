{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2021", "WebWorker"],
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "isolatedModules": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src", "test"]
}
